# ReactGuard Environment Configuration
# Copy to .env and fill in PRIVATE_KEY
# Contract addresses are pre-filled from the live Somnia testnet deployment

# ── Your wallet (needs STT for gas) ─────────────────────────────────────────
PRIVATE_KEY=your_private_key_here

# ── Somnia Testnet ───────────────────────────────────────────────────────────
SOMNIA_RPC_URL=https://dream-rpc.somnia.network

# ── Live Deployed Contracts (Somnia Testnet) ─────────────────────────────────
ORACLE_ADDRESS=0x2068372B91fa992Ac01277F27835244530A46299
REACTGUARD_ADDRESS=0x9c09b398d34481Dd65CdCDB07090FF2F2CC9E5f6
POOL_ADDRESS=0x7617Bbb75f203c7d181B45B632F548eF1406A26d

# ── Frontend vars (same addresses, Vite prefix) ──────────────────────────────
VITE_RPC_URL=https://dream-rpc.somnia.network
VITE_ORACLE_ADDRESS=0x2068372B91fa992Ac01277F27835244530A46299
VITE_REACTGUARD_ADDRESS=0x9c09b398d34481Dd65CdCDB07090FF2F2CC9E5f6
VITE_POOL_ADDRESS=0x7617Bbb75f203c7d181B45B632F548eF1406A26d
